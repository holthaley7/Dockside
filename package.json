{
  "name": "dockside",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm -w packages/server run dev",
    "dev:client": "npm -w packages/client run dev",
    "db:migrate": "npm -w packages/server run db:migrate",
    "db:seed": "npm -w packages/server run db:seed",
    "db:reset": "npm -w packages/server run db:reset",
    "build": "npm -w packages/client run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
